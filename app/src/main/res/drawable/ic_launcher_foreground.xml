        android:fillColor="#0000BFFF"
        android:strokeColor="#CC00BFFF"
        android:strokeWidth="1.2"
        android:pathData="M54,18 L73,28.5 L73,49.5 L90,59 L73,68.5 L73,89.5 L54,100 L35,89.5 L35,68.5 L18,59 L35,49.5 L35,28.5 Z" />

