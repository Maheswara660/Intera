<?xml version="1.0" encoding="utf-8"?>
<!--
  Intera launcher foreground — properly using only <path> and <group> elements
  valid in Android VectorDrawable format (no SVG-only <line> elements).
  All "lines" are expressed as stroke paths with M/L commands.
  Canvas: 108×108dp, safe zone: 72×72dp centred at (54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Outer hexagon ring (Electric Blue, hairline stroke) ── -->
